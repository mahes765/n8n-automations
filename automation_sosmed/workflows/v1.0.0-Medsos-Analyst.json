      "parameters": {
        "jsCode": "const msg = $('Get user message').first().json.message;\nconst text = msg?.text || \"\";\n\nconst links = text.match(/https?:\\/\\/(www\\.)?instagram\\.com\\/[^\\s]+/gi) || [];\n\nif (links.length === 0) {\n  return [{ json: { has_link: false, error_msg: \"Format link tidak valid atau kosong\" } }];\n}\n\nreturn links.map(link => ({\n  json: { has_link: true, ig_url: link, timestamp: new Date() }\n}));"
      },
