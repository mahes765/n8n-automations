                "jsCode": "// Check quota available - one-time purchase model\nconst entitlement = $json;\nconst quota_used = entitlement.quota_used || 0;\nconst quota_total = entitlement.quota_total || 0;\nconst quota_available = quota_used < quota_total;\n\nreturn [{\n  json: {\n    ...JSON.parse($('Parse Webhook Data1').first().json),\n    entitlement: entitlement,\n    quota_available: quota_available,\n    quota_remaining: quota_total - quota_used\n  }\n}];"
