NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

APP_SESSION_SECRET=change-this-to-a-long-random-secret
N8N_SHARED_SECRET=change-this-to-another-long-random-secret
N8N_MEDSOS_WEBHOOK_URL=https://n8n-instance.example.com/webhook/medsos-analysis-webhook
TELEGRAM_BOT_USERNAME=your_bot_without_at

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=change-this-to-a-long-random-secret-for-telegram-webhook
VALIDATE_TELEGRAM_IP=true

APIFY_API_KEY=your_apify_api_key
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-scraper  # atau actor ID lain
APIFY_DATASET_CACHE_TTL=3600  # Cache 1 jam
INSTAGRAM_SCRAPE_TIMEOUT=30000  # 30 detik timeout

MIDTRANS_MODE=real
MIDTRANS_SERVER_KEY=SB-Mid-server-your-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-key
MIDTRANS_IS_PRODUCTION=false
