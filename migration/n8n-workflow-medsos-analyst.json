                "jsCode": "// Check quota available\nconst quota_used = $json.quota_used || 0;\nconst quota_total = $json.quota_total || 0;\nconst quota_available = quota_used < quota_total;\n\nreturn [{\n  json: {\n    ...JSON.parse($('Parse Webhook Data').first().json.json),\n    entitlement: $json,\n    quota_available: quota_available,\n    quota_remaining: quota_total - quota_used\n  }\n}];"
